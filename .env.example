# Sociuly — variables d'environnement (exemple, sans valeurs)
# Copier en `.env.local` (non committé) et renseigner les valeurs.

# ─── Cartographie (SPEC §1 — MapLibre GL JS + tuiles OpenFreeMap) ───
# Aucune variable requise : OpenFreeMap (https://openfreemap.org) ne demande NI
# clé API NI quota. Le style des tuiles est codé en dur dans lib/map.ts.
# Pour auto-héberger les tuiles plus tard, voir https://openfreemap.org/quick_start/

# ─── Auth Supabase (SPEC §1 — magic link only, no password) ───
# URL du projet Supabase. Format : https://xxxxx.supabase.co
# Variable PUBLIQUE — exposée au client (créé via createBrowserClient).
NEXT_PUBLIC_SUPABASE_URL=

# Clé anon Supabase (clé publique, safe côté client).
# Les permissions réelles sont contraintes par les Row Level Security policies.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé service_role Supabase — SECRÈTE, jamais exposée au client.
# Utilisée pour les opérations admin (genL inscription, KYC clubs, etc.).
# Ne JAMAIS préfixer NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# URL de base de l'app, utilisée pour construire le `emailRedirectTo` du magic link.
# En dev : http://localhost:3000 — en preview Vercel : l'URL preview — en prod : https://sociuly.fr
# Optionnelle en dev : on retombe sur `request.headers.get('origin')`.
NEXT_PUBLIC_SITE_URL=

# ─── Base de données Prisma ↔ Supabase Postgres (CLAUDE.md §1 / §3) ───
# Deux chaînes distinctes (Dashboard Supabase → Project Settings → Database → Connection string).
# SECRÈTES — jamais préfixer NEXT_PUBLIC_.
#
# DATABASE_URL : connexion POOLÉE (pgBouncer, port 6543) — utilisée par le runtime
#   serverless Vercel. Indispensable en serverless pour ne pas saturer les connexions.
#   Suffixe obligatoire : ?pgbouncer=true&connection_limit=1
#   Format : postgresql://postgres.<ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL=

# DIRECT_URL : connexion DIRECTE (port 5432) — utilisée UNIQUEMENT par `prisma migrate`
#   (les migrations ne passent pas par le pooler).
#   Format : postgresql://postgres.<ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
DIRECT_URL=

# ─── API INSEE Sirene (CLAUDE.md §4 — vérification SIRET clubs & entreprises) ───
# Clé d'intégration du portail api.insee.fr (en-tête X-INSEE-Api-Key-Integration).
# SECRÈTE. Optionnelle : si absente, la vérification SIRET est déférée au KYC admin
# (le parcours d'onboarding/devis n'est pas bloqué). Cf. lib/account/siret.ts.
INSEE_SIRENE_API_KEY=
